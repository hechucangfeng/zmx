{
	"name": "zenxie",
	"version": "1.0.1",
	"description": "怎么写 - 汉字笔顺演示应用",
	"scripts": {
		"prepare-data": "bun run scripts/prepare-data.ts",
		"start": "bun run prepare-data && electrobun dev",
		"dev": "bun run prepare-data && electrobun dev --watch",
		"build:dev": "bun install && bun run prepare-data && electrobun build",
		"build:canary": "bun run prepare-data && electrobun build --env=canary",
		"build:stable": "bun run prepare-data && electrobun build --env=stable"
	},
	"dependencies": {
		"electrobun": "1.16.0",
		"gif.js": "^0.2.0",
		"hanzi-writer": "^3.7.3",
		"hanzi-writer-data": "^2.0.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/gif.js": "^0.2.5"
	}
}
